//@version=6
//=============================================================================
// TITAN X PROFESSIONAL
// Core Framework
//-----------------------------------------------------------------------------
// Version : 0.5.1-dev
// Build   : 0002
// Module  : Core Engine
// Status  : Development
//=============================================================================

indicator(
     title = "TITAN X Professional",
     shorttitle = "TITAN X",
     overlay = true,
     max_labels_count = 500,
     max_lines_count = 500,
     max_boxes_count = 500)

//=============================================================================
// VERSION
//=============================================================================

const string TITAN_VERSION = "0.5.3-dev"
const string TITAN_BUILD   = "0004"

//=============================================================================
// INPUTS
//=============================================================================

groupGeneral = "General"

showDashboard = input.bool(true, "Show Dashboard", group = groupGeneral)
debugMode     = input.bool(false, "Debug Mode", group = groupGeneral)
//=============================================================================
// STRUCTURE INPUTS
//=============================================================================

groupStructure = "Structure"

pivotLeft  = input.int(5, "Pivot Left", minval = 1, group = groupStructure)
pivotRight = input.int(5, "Pivot Right", minval = 1, group = groupStructure)

showStructureLabels = input.bool(true, "Show Structure Labels", group = groupStructure)
//=============================================================================
// LIQUIDITY INPUTS
//=============================================================================

groupLiquidity = "Liquidity"

eqTolerance = input.float(
     0.10,
     "Equal High/Low Tolerance (%)",
     minval = 0.01,
     step = 0.01,
     group = groupLiquidity)

showLiquidityLabels = input.bool(
     true,
     "Show Liquidity Labels",
     group = groupLiquidity)

//=============================================================================
// ASSET DETECTION
//=============================================================================

string symbolName = syminfo.ticker
string timeframeName = timeframe.period

string assetType = "UNKNOWN"

if str.contains(symbolName, "BTC")
    assetType := "CRYPTO"

else if str.contains(symbolName, "ETH")
    assetType := "CRYPTO"

else if str.contains(symbolName, "XAU")
    assetType := "METAL"

else if str.contains(symbolName, "XAG")
    assetType := "METAL"

else if str.contains(symbolName, "EUR")
    assetType := "FOREX"

else if str.contains(symbolName, "GBP")
    assetType := "FOREX"

//=============================================================================
// CORE VARIABLES
//=============================================================================

var string marketState = "UNKNOWN"
var float trendScore = 0.0
var float confidenceScore = 0.0
//=============================================================================
// STRUCTURE VARIABLES
//=============================================================================

var float lastSwingHigh = na
var float lastSwingLow  = na

var string structureDirection = "NEUTRAL"

var float structureScore = 0

var bool bullBOS = false
var bool bearBOS = false

var bool bullCHOCH = false
var bool bearCHOCH = false
//=============================================================================
// LIQUIDITY VARIABLES
//=============================================================================

var bool eqHighDetected = false
var bool eqLowDetected = false

var float equalHighPrice = na
var float equalLowPrice = na

var float liquidityScore = 0.0

//=============================================================================
// BOS / CHOCH
//=============================================================================

var float previousSwingHigh = na
var float previousSwingLow  = na

//=============================================================================
// UTILITY FUNCTIONS
//=============================================================================

roundPrice(price) =>
    math.round(price / syminfo.mintick) * syminfo.mintick

percent(a,b)=>
    b == 0 ? 0 : (a/b)*100

//=============================================================================
// DASHBOARD
//=============================================================================

var table dashboard = table.new(position.top_right,2,15)
getTrendDirection() =>

    string dir = "NEUTRAL"

    if trendScore >= 90
        dir := "ULTRA BULL"
    else if trendScore >= 75
        dir := "STRONG BULL"
    else if trendScore >= 60
        dir := "BULL"
    else if trendScore >= 40
        dir := "NEUTRAL"
    else if trendScore >= 25
        dir := "BEAR"
    else if trendScore >= 10
        dir := "STRONG BEAR"
    else
        dir := "ULTRA BEAR"

    dir
updateDashboard() =>

    table.cell(dashboard, 0, 0, "TITAN X")
    table.cell(dashboard, 1, 0, TITAN_VERSION)

    table.cell(dashboard, 0, 1, "Symbol")
    table.cell(dashboard, 1, 1, symbolName)

    table.cell(dashboard, 0, 2, "TF")
    table.cell(dashboard, 1, 2, timeframeName)

    table.cell(dashboard, 0, 3, "Asset")
    table.cell(dashboard, 1, 3, assetType)

    table.cell(dashboard, 0, 4, "Trend")
    table.cell(dashboard, 1, 4, getTrendDirection())

    table.cell(dashboard, 0, 5, "Score")
    table.cell(dashboard, 1, 5, str.tostring(math.round(trendScore)))

    table.cell(dashboard, 0, 6, "Decision")
    table.cell(dashboard, 1, 6, marketState)

    table.cell(dashboard, 0, 7, "Structure")
    table.cell(dashboard, 1, 7, structureDirection)

    table.cell(dashboard, 0, 8, "Struct Score")
    table.cell(dashboard, 1, 8, str.tostring(math.round(structureScore)))

    table.cell(dashboard,0,9,"BOS")
table.cell(dashboard,1,9,bullBOS ? "BULL" : bearBOS ? "BEAR" : "-")

table.cell(dashboard,0,10,"CHOCH")
table.cell(dashboard,1,10,bullCHOCH ? "BULL" : bearCHOCH ? "BEAR" : "-")

table.cell(dashboard,0,11,"Build")
table.cell(dashboard,1,11,TITAN_BUILD)
table.cell(dashboard,0,12,"EQH")
table.cell(dashboard,1,12,eqHighDetected ? "YES" : "NO")

table.cell(dashboard,0,13,"EQL")
table.cell(dashboard,1,13,eqLowDetected ? "YES" : "NO")

table.cell(dashboard,0,14,"Liquidity")
table.cell(dashboard,1,14,str.tostring(liquidityScore))
//=============================================================================
// LOGGER
//=============================================================================

log(message)=>

    if debugMode and barstate.islast
        label.new(
             bar_index,
             high,
             message,
             style=label.style_label_down)

//=============================================================================
// ENGINE PLACEHOLDERS
//=============================================================================

//=============================================================================
// TREND ENGINE
//=============================================================================

// EMAs
ema20  = ta.ema(close,20)
ema50  = ta.ema(close,50)
ema100 = ta.ema(close,100)
ema200 = ta.ema(close,200)

//------------------------------------------------------------
// Trend Score
//------------------------------------------------------------
calculateTrend()=>

    float score = 0

    // EMA Alignment
    score += ema20 > ema50 ? 15 : 0
    score += ema50 > ema100 ? 15 : 0
    score += ema100 > ema200 ? 15 : 0

    // Price Position
    score += close > ema20 ? 10 : 0
    score += close > ema50 ? 10 : 0
    score += close > ema100 ? 10 : 0
    score += close > ema200 ? 10 : 0

    // EMA Slope
    score += ema20 > ema20[1] ? 5 : 0
    score += ema50 > ema50[1] ? 5 : 0
    score += ema100 > ema100[1] ? 3 : 0
    score += ema200 > ema200[1] ? 2 : 0

    score

//------------------------------------------------------------
// Confidence
//------------------------------------------------------------
calculateConfidence()=>

    float confidence = trendScore

    confidence

//------------------------------------------------------------
// Decision
//------------------------------------------------------------
calculateDecision()=>

    string result="WAIT"

    if trendScore >=80
        result:="BUY"

    else if trendScore<=20
        result:="SELL"

    result

//------------------------------------------------------------
// Trend Direction
//------------------------------------------------------------

    //=============================================================================
// SMART MARKET STRUCTURE ENGINE
//=============================================================================

pivotHigh = ta.pivothigh(high, pivotLeft, pivotRight)
pivotLow  = ta.pivotlow(low, pivotLeft, pivotRight)

if not na(pivotHigh)

    if not na(lastSwingHigh)

        if pivotHigh > lastSwingHigh

            structureDirection := "HH"

            structureScore := math.min(structureScore + 15, 100)

            if showStructureLabels
                label.new(
                    bar_index-pivotRight,
                    pivotHigh,
                    "HH",
                    style=label.style_label_down,
                    color=color.green,
                    textcolor=color.white)

        else

            structureDirection := "LH"

            structureScore := math.max(structureScore - 15, 0)

            if showStructureLabels
                label.new(
                    bar_index-pivotRight,
                    pivotHigh,
                    "LH",
                    style=label.style_label_down,
                    color=color.red,
                    textcolor=color.white)

    previousSwingHigh := lastSwingHigh
lastSwingHigh := pivotHigh

//------------------------------------------------------

//------------------------------------------------------
// LOW STRUCTURE
//------------------------------------------------------

if not na(pivotLow)

    if not na(lastSwingLow)

        if pivotLow > lastSwingLow

            structureDirection := "HL"
            structureScore := math.min(structureScore + 15, 100)

            if showStructureLabels
                label.new(
                    bar_index - pivotRight,
                    pivotLow,
                    "HL",
                    style = label.style_label_up,
                    color = color.green,
                    textcolor = color.white
                )

        else

            structureDirection := "LL"
            structureScore := math.max(structureScore - 15, 0)

            if showStructureLabels
                label.new(
                    bar_index - pivotRight,
                    pivotLow,
                    "LL",
                    style = label.style_label_up,
                    color = color.red,
                    textcolor = color.white
                )

    previousSwingLow := lastSwingLow
    lastSwingLow := pivotLow
    //=============================================================================
// LIQUIDITY ENGINE
//=============================================================================

eqHighDetected := false
eqLowDetected := false

if not na(lastSwingHigh) and not na(previousSwingHigh)

    float highDiff =
         math.abs(lastSwingHigh - previousSwingHigh)

    float highTolerance =
         lastSwingHigh * eqTolerance / 100

    if highDiff <= highTolerance

        eqHighDetected := true
        equalHighPrice := lastSwingHigh

        liquidityScore :=
             math.min(liquidityScore + 20, 100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 equalHighPrice,
                 "EQH",
                 style = label.style_label_down,
                 color = color.orange,
                 textcolor = color.white)

if not na(lastSwingLow) and not na(previousSwingLow)

    float lowDiff =
         math.abs(lastSwingLow - previousSwingLow)

    float lowTolerance =
         lastSwingLow * eqTolerance / 100

    if lowDiff <= lowTolerance

        eqLowDetected := true
        equalLowPrice := lastSwingLow

        liquidityScore :=
             math.min(liquidityScore + 20,100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 equalLowPrice,
                 "EQL",
                 style = label.style_label_up,
                 color = color.orange,
                 textcolor = color.white)
//=============================================================================
// BREAK OF STRUCTURE
//=============================================================================

bullBOS := false
bearBOS := false

if not na(lastSwingHigh)
    bullBOS := close > lastSwingHigh

if not na(lastSwingLow)
    bearBOS := close < lastSwingLow
    //=============================================================================
// CHANGE OF CHARACTER
//=============================================================================

bullCHOCH := false
bearCHOCH := false

if structureDirection == "LL" and bullBOS
    bullCHOCH := true

if structureDirection == "HH" and bearBOS
    bearCHOCH := true
//=============================================================================
// MAIN
//=============================================================================

trendScore := calculateTrend()

confidenceScore := calculateConfidence()

marketState := calculateDecision()

if showDashboard and barstate.islast
    updateDashboard()

plot(ema20,"EMA20",color=color.orange,linewidth=2)
plot(ema50,"EMA50",color=color.blue)
plot(ema100,"EMA100",color=color.green)
plot(ema200,"EMA200",color=color.red)
