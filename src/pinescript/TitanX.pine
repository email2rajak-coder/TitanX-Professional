    table.cell(dashboard, 0, 7, "OB Score", text_color=color.white)
    table.cell(dashboard, 1, 7, str.tostring(math.round(orderBlockScore)), text_color=color.white)

    table.cell(dashboard, 0, 8, "PD Score", text_color=color.white)
