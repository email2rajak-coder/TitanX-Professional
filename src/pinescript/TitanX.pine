//@version=6
//=============================================================================
// TITAN X PROFESSIONAL
// Core Framework
//-----------------------------------------------------------------------------
// Version : 0.5.1-dev
// Build   : 0002
// Module  : Core Engine
// Status  : Development
//=============================================================================

indicator(
     title = "TITAN X Professional",
     shorttitle = "TITAN X",
     overlay = true,
     max_labels_count = 500,
     max_lines_count = 500,
     max_boxes_count = 500)

//=============================================================================
// VERSION
//=============================================================================

const string TITAN_VERSION = "0.5.3-dev"
const string TITAN_BUILD   = "0004"

//=============================================================================
// INPUTS
//=============================================================================

groupGeneral = "General"

showDashboard = input.bool(true, "Show Dashboard", group = groupGeneral)
debugMode     = input.bool(false, "Debug Mode", group = groupGeneral)
//=============================================================================
// STRUCTURE INPUTS
//=============================================================================

groupStructure = "Structure"

pivotLeft  = input.int(5, "Pivot Left", minval = 1, group = groupStructure)
pivotRight = input.int(5, "Pivot Right", minval = 1, group = groupStructure)

showStructureLabels = input.bool(true, "Show Structure Labels", group = groupStructure)
//=============================================================================
// LIQUIDITY INPUTS
//=============================================================================

groupLiquidity = "Liquidity"

eqTolerance = input.float(
     0.10,
     "Equal High/Low Tolerance (%)",
     minval = 0.01,
     step = 0.01,
     group = groupLiquidity)

showLiquidityLabels = input.bool(
     true,
     "Show Liquidity Labels",
     group = groupLiquidity)
     //=============================================================================
// MULTI TIMEFRAME
//=============================================================================

groupMTF = "Multi Timeframe"

enableMTF = input.bool(true, "Enable MTF", group = groupMTF)

higherTF = input.timeframe("60", "Higher Timeframe", group = groupMTF)

showMTFDashboard = input.bool(true, "Show MTF Info", group = groupMTF)
//=============================================================================
// FAIR VALUE GAP
//=============================================================================

groupFVG = "Fair Value Gap"

showFVG = input.bool(true, "Show Fair Value Gaps", group = groupFVG)

minFVGTicks = input.int(5, "Minimum Gap (Ticks)", minval = 1, group = groupFVG)
//=============================================================================
// ORDER BLOCK
//=============================================================================

groupOB = "Order Blocks"

showOrderBlocks = input.bool(true, "Show Order Blocks", group = groupOB)

obLookback = input.int(20, "Lookback", minval = 5, group = groupOB)
//=============================================================================
// PREMIUM / DISCOUNT
//=============================================================================

groupPD = "Premium / Discount"

showPDZones = input.bool(true, "Show Premium/Discount", group = groupPD)

pdLookback = input.int(100, "Swing Lookback", minval = 20, group = groupPD)
//=============================================================================
// SESSION ENGINE
//=============================================================================

groupSession = "Session"

showSessions = input.bool(true, "Show Sessions", group = groupSession)

showKillZones = input.bool(true, "Show Kill Zones", group = groupSession)

sessionTimezone = input.string(
     "Etc/UTC",
     "Timezone",
     options = ["Etc/UTC","Europe/London","America/New_York"],
     group = groupSession)

//=============================================================================
// ASSET DETECTION
//=============================================================================

string symbolName = syminfo.ticker
string timeframeName = timeframe.period

string assetType = "UNKNOWN"

if str.contains(symbolName, "BTC")
    assetType := "CRYPTO"

else if str.contains(symbolName, "ETH")
    assetType := "CRYPTO"

else if str.contains(symbolName, "XAU")
    assetType := "METAL"

else if str.contains(symbolName, "XAG")
    assetType := "METAL"

else if str.contains(symbolName, "EUR")
    assetType := "FOREX"

else if str.contains(symbolName, "GBP")
    assetType := "FOREX"

//=============================================================================
// CORE VARIABLES
//=============================================================================

var string marketState = "UNKNOWN"
var float trendScore = 0.0
var float confidenceScore = 0.0
//=============================================================================
// STRUCTURE VARIABLES
//=============================================================================

var float lastSwingHigh = na
var float lastSwingLow  = na

var string structureDirection = "NEUTRAL"

var float structureScore = 0

var bool bullBOS = false
var bool bearBOS = false

var bool bullCHOCH = false
var bool bearCHOCH = false
//=============================================================================
// LIQUIDITY VARIABLES
//=============================================================================

var bool eqHighDetected = false
var bool eqLowDetected = false

var float equalHighPrice = na
var float equalLowPrice = na

var float liquidityScore = 0.0
//=============================================================================
// LIQUIDITY SWEEP VARIABLES
//=============================================================================

var bool bullSweep = false
var bool bearSweep = false

var float lastSweepPrice = na

var float sweepScore = 0.0
//=============================================================================
// CONFLUENCE VARIABLES
//=============================================================================

var float confluenceScore = 0.0
var string marketBias = "NEUTRAL"

var bool trendAligned = false
var bool structureAligned = false
var bool liquidityAligned = false
//=============================================================================
// MTF VARIABLES
//=============================================================================

var string htfTrend = "UNKNOWN"
var float htfEMA20 = na
var float htfEMA50 = na

var bool htfBullish = false
var bool htfBearish = false

var float mtfScore = 0.0
//=============================================================================
// FVG VARIABLES
//=============================================================================

var bool bullFVG = false
var bool bearFVG = false

var float bullFVGHigh = na
var float bullFVGLow = na

var float bearFVGHigh = na
var float bearFVGLow = na

var float fvgScore = 0.0
//=============================================================================
// ORDER BLOCK VARIABLES
//=============================================================================

var bool bullOB = false
var bool bearOB = false

var float bullOBHigh = na
var float bullOBLow = na

var float bearOBHigh = na
var float bearOBLow = na

var float orderBlockScore = 0.0
//=============================================================================
// PREMIUM / DISCOUNT VARIABLES
//=============================================================================

var float premiumLevel = na
var float equilibriumLevel = na
var float discountLevel = na

var string pdState = "UNKNOWN"

var float pdScore = 0.0
//=============================================================================
// SESSION VARIABLES
//=============================================================================

var bool asianSession = false
var bool londonSession = false
var bool newYorkSession = false

var bool londonKillZone = false
var bool newYorkKillZone = false

var float sessionHigh = na
var float sessionLow = na

var string activeSession = "NONE"

var float sessionScore = 0.0
//=============================================================================
// BOS / CHOCH
//=============================================================================

var float previousSwingHigh = na
var float previousSwingLow  = na

//=============================================================================
// UTILITY FUNCTIONS
//=============================================================================

roundPrice(price) =>
    math.round(price / syminfo.mintick) * syminfo.mintick

percent(a,b)=>
    b == 0 ? 0 : (a/b)*100

//=============================================================================
// DASHBOARD
//=============================================================================

var table dashboard = table.new(position.top_right,2,38)
getTrendDirection() =>

    string dir = "NEUTRAL"

    if trendScore >= 90
        dir := "ULTRA BULL"
    else if trendScore >= 75
        dir := "STRONG BULL"
    else if trendScore >= 60
        dir := "BULL"
    else if trendScore >= 40
        dir := "NEUTRAL"
    else if trendScore >= 25
        dir := "BEAR"
    else if trendScore >= 10
        dir := "STRONG BEAR"
    else
        dir := "ULTRA BEAR"

    dir
updateDashboard() =>

    table.cell(dashboard, 0, 0, "TITAN X")
    table.cell(dashboard, 1, 0, TITAN_VERSION)

    table.cell(dashboard, 0, 1, "Symbol")
    table.cell(dashboard, 1, 1, symbolName)

    table.cell(dashboard, 0, 2, "TF")
    table.cell(dashboard, 1, 2, timeframeName)

    table.cell(dashboard, 0, 3, "Asset")
    table.cell(dashboard, 1, 3, assetType)

    table.cell(dashboard, 0, 4, "Trend")
    table.cell(dashboard, 1, 4, getTrendDirection())

    table.cell(dashboard, 0, 5, "Score")
    table.cell(dashboard, 1, 5, str.tostring(math.round(trendScore)))

    table.cell(dashboard, 0, 6, "Decision")
    table.cell(dashboard, 1, 6, marketState)

    table.cell(dashboard, 0, 7, "Structure")
    table.cell(dashboard, 1, 7, structureDirection)

    table.cell(dashboard, 0, 8, "Struct Score")
    table.cell(dashboard, 1, 8, str.tostring(math.round(structureScore)))

    table.cell(dashboard,0,9,"BOS")
table.cell(dashboard,1,9,bullBOS ? "BULL" : bearBOS ? "BEAR" : "-")

table.cell(dashboard,0,10,"CHOCH")
table.cell(dashboard,1,10,bullCHOCH ? "BULL" : bearCHOCH ? "BEAR" : "-")

table.cell(dashboard,0,11,"Build")
table.cell(dashboard,1,11,TITAN_BUILD)
table.cell(dashboard,0,12,"EQH")
table.cell(dashboard,1,12,eqHighDetected ? "YES" : "NO")

table.cell(dashboard,0,13,"EQL")
table.cell(dashboard,1,13,eqLowDetected ? "YES" : "NO")

table.cell(dashboard,0,14,"Liquidity")
table.cell(dashboard,1,14,str.tostring(liquidityScore))
table.cell(dashboard,0,15,"Bull Sweep")
table.cell(dashboard,1,15,bullSweep ? "YES" : "-")

table.cell(dashboard,0,16,"Bear Sweep")
table.cell(dashboard,1,16,bearSweep ? "YES" : "-")

table.cell(dashboard,0,17,"Sweep Score")
table.cell(dashboard,1,17,str.tostring(math.round(sweepScore)))
table.cell(dashboard,0,18,"Bias")
table.cell(dashboard,1,18,marketBias)

table.cell(dashboard,0,19,"Confluence")
table.cell(dashboard,1,19,str.tostring(math.round(confluenceScore)))

table.cell(dashboard,0,20,"Ready")
table.cell(dashboard, 1, 20, confluenceScore >= 80 ? "YES" : "WAIT")

table.cell(dashboard,0,21,"HTF Trend")
table.cell(dashboard,1,21,htfTrend)

table.cell(dashboard,0,22,"MTF Score")
table.cell(dashboard,1,22,str.tostring(math.round(mtfScore)))

table.cell(dashboard,0,23,"MTF Align")
table.cell(dashboard,1,23,mtfScore >= 50 ? "YES" : "NO")

table.cell(dashboard,0,24,"Bull FVG")
table.cell(dashboard,1,24,bullFVG ? "YES" : "-")

table.cell(dashboard,0,25,"Bear FVG")
table.cell(dashboard,1,25,bearFVG ? "YES" : "-")

table.cell(dashboard,0,26,"FVG Score")
table.cell(dashboard,1,26,str.tostring(math.round(fvgScore)))

table.cell(dashboard,0,27,"Bull OB")
table.cell(dashboard,1,27,bullOB ? "YES" : "-")

table.cell(dashboard,0,28,"Bear OB")
table.cell(dashboard,1,28,bearOB ? "YES" : "-")

table.cell(dashboard,0,29,"OB Score")
table.cell(dashboard,1,29,str.tostring(math.round(orderBlockScore)))

table.cell(dashboard,0,30,"PD Zone")
table.cell(dashboard,1,30,pdState)

table.cell(dashboard,0,31,"PD Score")
table.cell(dashboard,1,31,str.tostring(math.round(pdScore)))

table.cell(dashboard,0,32,"EQ")
table.cell(dashboard,1,32,str.tostring(math.round(equilibriumLevel)))

table.cell(dashboard,0,33,"Session")
table.cell(dashboard,1,33,activeSession)

table.cell(dashboard,0,34,"Kill Zone")
table.cell(dashboard,1,34,
     londonKillZone ? "LONDON" :
     newYorkKillZone ? "NEW YORK" : "-")

table.cell(dashboard,0,35,"Session High")
table.cell(dashboard,1,35,str.tostring(sessionHigh))

table.cell(dashboard,0,36,"Session Low")
table.cell(dashboard,1,36,str.tostring(sessionLow))

table.cell(dashboard,0,37,"Session Score")
table.cell(dashboard,1,37,str.tostring(math.round(sessionScore)))
//=============================================================================
// LOGGER
//=============================================================================

log(message)=>

    if debugMode and barstate.islast
        label.new(
             bar_index,
             high,
             message,
             style=label.style_label_down)

//=============================================================================
// ENGINE PLACEHOLDERS
//=============================================================================

//=============================================================================
// TREND ENGINE
//=============================================================================

// EMAs
ema20  = ta.ema(close,20)
ema50  = ta.ema(close,50)
ema100 = ta.ema(close,100)
ema200 = ta.ema(close,200)

//------------------------------------------------------------
// Trend Score
//------------------------------------------------------------
calculateTrend()=>

    float score = 0

    // EMA Alignment
    score += ema20 > ema50 ? 15 : 0
    score += ema50 > ema100 ? 15 : 0
    score += ema100 > ema200 ? 15 : 0

    // Price Position
    score += close > ema20 ? 10 : 0
    score += close > ema50 ? 10 : 0
    score += close > ema100 ? 10 : 0
    score += close > ema200 ? 10 : 0

    // EMA Slope
    score += ema20 > ema20[1] ? 5 : 0
    score += ema50 > ema50[1] ? 5 : 0
    score += ema100 > ema100[1] ? 3 : 0
    score += ema200 > ema200[1] ? 2 : 0

    score
    //=============================================================================
// HIGHER TIMEFRAME DATA
//=============================================================================

if enableMTF

    htfEMA20 := request.security(
        syminfo.tickerid,
        higherTF,
        ta.ema(close,20))

    htfEMA50 := request.security(
        syminfo.tickerid,
        higherTF,
        ta.ema(close,50))

    htfBullish := htfEMA20 > htfEMA50
    htfBearish := htfEMA20 < htfEMA50

//------------------------------------------------------------
// Confidence
//------------------------------------------------------------
calculateConfidence()=>

    float confidence = trendScore

    confidence

//------------------------------------------------------------
// Decision
//------------------------------------------------------------
calculateDecision()=>

    string result="WAIT"

    if trendScore >=80
        result:="BUY"

    else if trendScore<=20
        result:="SELL"

    result

//------------------------------------------------------------
// Trend Direction
//------------------------------------------------------------

    //=============================================================================
// SMART MARKET STRUCTURE ENGINE
//=============================================================================

pivotHigh = ta.pivothigh(high, pivotLeft, pivotRight)
pivotLow  = ta.pivotlow(low, pivotLeft, pivotRight)

if not na(pivotHigh)

    if not na(lastSwingHigh)

        if pivotHigh > lastSwingHigh

            structureDirection := "HH"

            structureScore := math.min(structureScore + 15, 100)

            if showStructureLabels
                label.new(
                    bar_index-pivotRight,
                    pivotHigh,
                    "HH",
                    style=label.style_label_down,
                    color=color.green,
                    textcolor=color.white)

        else

            structureDirection := "LH"

            structureScore := math.max(structureScore - 15, 0)

            if showStructureLabels
                label.new(
                    bar_index-pivotRight,
                    pivotHigh,
                    "LH",
                    style=label.style_label_down,
                    color=color.red,
                    textcolor=color.white)

    previousSwingHigh := lastSwingHigh
lastSwingHigh := pivotHigh

//------------------------------------------------------

//------------------------------------------------------
// LOW STRUCTURE
//------------------------------------------------------

if not na(pivotLow)

    if not na(lastSwingLow)

        if pivotLow > lastSwingLow

            structureDirection := "HL"
            structureScore := math.min(structureScore + 15, 100)

            if showStructureLabels
                label.new(
                    bar_index - pivotRight,
                    pivotLow,
                    "HL",
                    style = label.style_label_up,
                    color = color.green,
                    textcolor = color.white
                )

        else

            structureDirection := "LL"
            structureScore := math.max(structureScore - 15, 0)

            if showStructureLabels
                label.new(
                    bar_index - pivotRight,
                    pivotLow,
                    "LL",
                    style = label.style_label_up,
                    color = color.red,
                    textcolor = color.white
                )

    previousSwingLow := lastSwingLow
    lastSwingLow := pivotLow
    //=============================================================================
// LIQUIDITY ENGINE
//=============================================================================

eqHighDetected := false
eqLowDetected := false

if not na(lastSwingHigh) and not na(previousSwingHigh)

    float highDiff =
         math.abs(lastSwingHigh - previousSwingHigh)

    float highTolerance =
         lastSwingHigh * eqTolerance / 100

    if highDiff <= highTolerance

        eqHighDetected := true
        equalHighPrice := lastSwingHigh

        liquidityScore :=
             math.min(liquidityScore + 20, 100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 equalHighPrice,
                 "EQH",
                 style = label.style_label_down,
                 color = color.orange,
                 textcolor = color.white)

if not na(lastSwingLow) and not na(previousSwingLow)

    float lowDiff =
         math.abs(lastSwingLow - previousSwingLow)

    float lowTolerance =
         lastSwingLow * eqTolerance / 100

    if lowDiff <= lowTolerance

        eqLowDetected := true
        equalLowPrice := lastSwingLow

        liquidityScore :=
             math.min(liquidityScore + 20,100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 equalLowPrice,
                 "EQL",
                 style = label.style_label_up,
                 color = color.orange,
                 textcolor = color.white)
                 //=============================================================================
// LIQUIDITY SWEEP ENGINE
//=============================================================================

bullSweep := false
bearSweep := false

//------------------------------------
// Bearish Sweep
//------------------------------------

if eqHighDetected

    if high > equalHighPrice and close < equalHighPrice

        bearSweep := true
        lastSweepPrice := high

        sweepScore := math.min(sweepScore + 40, 100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 high,
                 "Bear Sweep",
                 style = label.style_label_down,
                 color = color.red,
                 textcolor = color.white)

//------------------------------------
// Bullish Sweep
//------------------------------------

if eqLowDetected

    if low < equalLowPrice and close > equalLowPrice

        bullSweep := true
        lastSweepPrice := low

        sweepScore := math.min(sweepScore + 40, 100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 low,
                 "Bull Sweep",
                 style = label.style_label_up,
                 color = color.lime,
                 textcolor = color.black)
                 //=============================================================================
// CONFLUENCE ENGINE
//=============================================================================

confluenceScore := 0

//----------------------------------------------------
// Trend
//----------------------------------------------------

trendAligned := trendScore >= 70

if trendAligned
    confluenceScore += 30

//----------------------------------------------------
// Structure
//----------------------------------------------------

structureAligned :=
     structureDirection == "HH" or
     structureDirection == "HL"

if structureAligned
    confluenceScore += 30

//----------------------------------------------------
// Liquidity
//----------------------------------------------------

liquidityAligned :=
     bullSweep or
     bearSweep or
     eqHighDetected or
     eqLowDetected

if liquidityAligned
    confluenceScore += 40

//----------------------------------------------------
// Market Bias
//----------------------------------------------------

marketBias := "NEUTRAL"

if confluenceScore >= 80
    marketBias := "BULLISH"

else if confluenceScore <= 20
    marketBias := "BEARISH"
    //=============================================================================
// MTF ENGINE
//=============================================================================

mtfScore := 0

if enableMTF

    if htfBullish
        mtfScore += 50

    if htfBearish
        mtfScore -= 50

    if htfBullish and trendScore >= 70
        mtfScore += 50

    if htfBearish and trendScore <= 30
        mtfScore -= 50

if mtfScore > 100
    mtfScore := 100

if mtfScore < -100
    mtfScore := -100

if htfBullish
    htfTrend := "BULLISH"

else if htfBearish
    htfTrend := "BEARISH"

else
    htfTrend := "SIDEWAYS"
    //=============================================================================
// FAIR VALUE GAP ENGINE
//=============================================================================

bullFVG := false
bearFVG := false

//-------------------------------------
// Bullish FVG
//-------------------------------------

if low > high[2]

    gapSize = (low - high[2]) / syminfo.mintick

    if gapSize >= minFVGTicks

        bullFVG := true

        bullFVGHigh := low
        bullFVGLow := high[2]

        fvgScore := math.min(fvgScore + 20,100)

        if showFVG
            box.new(
                 bar_index-2,
                 low,
                 bar_index,
                 high[2],
                 bgcolor=color.new(color.green,85),
                 border_color=color.green)

//-------------------------------------
// Bearish FVG
//-------------------------------------

if high < low[2]

    gapSize = (low[2]-high)/syminfo.mintick

    if gapSize >= minFVGTicks

        bearFVG := true

        bearFVGHigh := low[2]
        bearFVGLow := high

        fvgScore := math.min(fvgScore+20,100)

        if showFVG
            box.new(
                 bar_index-2,
                 low[2],
                 bar_index,
                 high,
                 bgcolor=color.new(color.red,85),
                 border_color=color.red)
                //=============================================================================
// ORDER BLOCK ENGINE
//=============================================================================

bullOB := false
bearOB := false

//--------------------------------------------------
// Bullish Order Block
//--------------------------------------------------

if ta.lowest(low, obLookback) == low and close > open

    bullOB := true

    bullOBHigh := high
    bullOBLow := low

    orderBlockScore := math.min(orderBlockScore + 15, 100)

    if showOrderBlocks
        box.new(
            bar_index,
            high,
            bar_index + 5,
            low,
            bgcolor = color.new(color.green, 85),
            border_color = color.green)

//--------------------------------------------------
// Bearish Order Block
//--------------------------------------------------

if ta.highest(high, obLookback) == high and close < open

    bearOB := true

    bearOBHigh := high
    bearOBLow := low

    orderBlockScore := math.min(orderBlockScore + 15, 100)

    if showOrderBlocks
        box.new(
            bar_index,
            high,
            bar_index + 5,
            low,
            bgcolor = color.new(color.red, 85),
            border_color = color.red)
            //=============================================================================
// PREMIUM / DISCOUNT ENGINE
//=============================================================================

swingHigh = ta.highest(high, pdLookback)
swingLow  = ta.lowest(low, pdLookback)

priceRange = swingHigh - swingLow

premiumLevel := swingLow + priceRange * 0.75
equilibriumLevel := swingLow + priceRange * 0.50
discountLevel := swingLow + priceRange * 0.25
pdScore := 50

if close >= premiumLevel
    pdState := "PREMIUM"
    pdScore := 0

else if close <= discountLevel
    pdState := "DISCOUNT"
    pdScore := 100

else
    pdState := "EQUILIBRIUM"
    pdScore := 50
    //=============================================================================
// SESSION DETECTION
//=============================================================================

currentHour = hour(time, sessionTimezone)

asianSession := currentHour >= 0 and currentHour < 8

londonSession := currentHour >= 8 and currentHour < 16

newYorkSession := currentHour >= 13 and currentHour < 22

londonKillZone := currentHour >= 8 and currentHour < 10

newYorkKillZone := currentHour >= 13 and currentHour < 16

activeSession := "NONE"

if asianSession
    activeSession := "ASIA"

if londonSession
    activeSession := "LONDON"

if newYorkSession
    activeSession := "NEW YORK"
    // Session High Low

if activeSession != activeSession[1]

    sessionHigh := high
    sessionLow := low

else

    sessionHigh := math.max(sessionHigh, high)
    sessionLow := math.min(sessionLow, low)
    sessionScore := 50

if londonKillZone
    sessionScore := 100

else if newYorkKillZone
    sessionScore := 95

else if londonSession
    sessionScore := 80

else if newYorkSession
    sessionScore := 75

else if asianSession
    sessionScore := 40
//=============================================================================
// BREAK OF STRUCTURE
//=============================================================================

bullBOS := false
bearBOS := false

if not na(lastSwingHigh)
    bullBOS := close > lastSwingHigh

if not na(lastSwingLow)
    bearBOS := close < lastSwingLow
    //=============================================================================
// CHANGE OF CHARACTER
//=============================================================================

bullCHOCH := false
bearCHOCH := false

if structureDirection == "LL" and bullBOS
    bullCHOCH := true

if structureDirection == "HH" and bearBOS
    bearCHOCH := true
//=============================================================================
// MAIN
//=============================================================================

trendScore := calculateTrend()

confidenceScore := calculateConfidence()

marketState := calculateDecision()

if showDashboard and barstate.islast
    updateDashboard()

plot(ema20,"EMA20",color=color.orange,linewidth=2)
plot(ema50,"EMA50",color=color.blue)
plot(ema100,"EMA100",color=color.green)
plot(ema200,"EMA200",color=color.red)
plot(showPDZones ? premiumLevel : na,
     title = "Premium",
     color = color.red)

plot(showPDZones ? equilibriumLevel : na,
     title = "Equilibrium",
     color = color.yellow)

plot(showPDZones ? discountLevel : na,
     title = "Discount",
     color = color.green)
plot(showSessions ? sessionHigh : na,
     title="Session High",
     color=color.green)

plot(showSessions ? sessionLow : na,
     title="Session Low",
     color=color.red)