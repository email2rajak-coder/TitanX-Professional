    table.cell(dashboard, 0, 0, "TITAN X — STATISTICS", text_color=color.white, bgcolor=color.new(#2962ff, 0))
    table.cell(dashboard, 1, 0, TITAN_BUILD, text_color=color.white, bgcolor=color.new(#2962ff, 0))

    table.cell(dashboard, 0, 1, "Trend Score", text_color=color.white)
    table.cell(dashboard, 1, 1, str.tostring(math.round(trendScore)), text_color=color.white)

    table.cell(dashboard, 0, 2, "Structure Score", text_color=color.white)
    table.cell(dashboard, 1, 2, str.tostring(math.round(structureScore)), text_color=color.white)

    table.cell(dashboard, 0, 3, "Liquidity Score", text_color=color.white)
    table.cell(dashboard, 1, 3, str.tostring(math.round(liquidityScore)), text_color=color.white)

    table.cell(dashboard, 0, 4, "Sweep Score", text_color=color.white)
