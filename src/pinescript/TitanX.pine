//@version=6
//=============================================================================
// TITAN X PROFESSIONAL
// Core Framework
//-----------------------------------------------------------------------------
// Version : 0.5.1-dev
// Build   : 0002
// Module  : Core Engine
// Status  : Development
//=============================================================================

indicator(
     title = "TITAN X Professional",
     shorttitle = "TITAN X",
     overlay = true,
     max_labels_count = 500,
     max_lines_count = 500,
     max_boxes_count = 500)

//=============================================================================
// VERSION
//=============================================================================

const string TITAN_VERSION = "0.5.3-dev"
const string TITAN_BUILD   = "0004"

//=============================================================================
// INPUTS
//=============================================================================

groupGeneral = "General"

showDashboard = input.bool(true, "Show Dashboard", group = groupGeneral)
debugMode     = input.bool(false, "Debug Mode", group = groupGeneral)
//==================================================
// DASHBOARD
//==================================================

groupDashboard = "Dashboard"

dashboardPage = input.string(
    "SUMMARY",
    "Dashboard Page",
    options = [
        "SUMMARY",
        "STRUCTURE",
        "SMART MONEY",
        "EXECUTION",
        "STATISTICS",
        "DEBUG"
    ],
    group = groupDashboard)
//=====================================================
// TRADE SETUP PANEL
//=====================================================

groupTradeBox = "Trade Setup"

showTradeBox = input.bool(
     true,
     "Show Trade Setup",
     group = groupTradeBox)

tradeBoxPosition = input.string(
     "Bottom Right",
     "Position",
     options=[
     "Top Left",
     "Top Right",
     "Bottom Left",
     "Bottom Right"],
     group=groupTradeBox)    
//=============================================================================
// STRUCTURE INPUTS
//=============================================================================

groupStructure = "Structure"

pivotLeft  = input.int(5, "Pivot Left", minval = 1, group = groupStructure)
pivotRight = input.int(5, "Pivot Right", minval = 1, group = groupStructure)

showStructureLabels = input.bool(true, "Show Structure Labels", group = groupStructure)
//=============================================================================
// LIQUIDITY INPUTS
//=============================================================================

groupLiquidity = "Liquidity"

eqTolerance = input.float(
     0.10,
     "Equal High/Low Tolerance (%)",
     minval = 0.01,
     step = 0.01,
     group = groupLiquidity)

showLiquidityLabels = input.bool(
     true,
     "Show Liquidity Labels",
     group = groupLiquidity)

//=============================================================================
// MULTI TIMEFRAME
//=============================================================================

groupMTF = "Multi Timeframe"

enableMTF = input.bool(true, "Enable MTF", group = groupMTF)

higherTF = input.timeframe("60", "Higher Timeframe", group = groupMTF)

showMTFDashboard = input.bool(true, "Show MTF Info", group = groupMTF)
//=============================================================================
// FAIR VALUE GAP
//=============================================================================

groupFVG = "Fair Value Gap"

showFVG = input.bool(true, "Show Fair Value Gaps", group = groupFVG)

minFVGTicks = input.int(5, "Minimum Gap (Ticks)", minval = 1, group = groupFVG)
//=============================================================================
// ORDER BLOCK
//=============================================================================

groupOB = "Order Blocks"

showOrderBlocks = input.bool(true, "Show Order Blocks", group = groupOB)

obLookback = input.int(20, "Lookback", minval = 5, group = groupOB)
//=============================================================================
// PREMIUM / DISCOUNT
//=============================================================================

groupPD = "Premium / Discount"

showPDZones = input.bool(true, "Show Premium/Discount", group = groupPD)

pdLookback = input.int(100, "Swing Lookback", minval = 20, group = groupPD)
//=============================================================================
// SESSION ENGINE
//=============================================================================

groupSession = "Session"

showSessions = input.bool(true, "Show Sessions", group = groupSession)

showKillZones = input.bool(true, "Show Kill Zones", group = groupSession)

sessionTimezone = input.string(
     "Etc/UTC",
     "Timezone",
     options = ["Etc/UTC","Europe/London","America/New_York"],
     group = groupSession)


//=============================================================================
// ASSET DETECTION
//=============================================================================

string symbolName = syminfo.ticker
string timeframeName = timeframe.period

string assetType = "UNKNOWN"

if str.contains(symbolName, "BTC")
    assetType := "CRYPTO"

else if str.contains(symbolName, "ETH")
    assetType := "CRYPTO"

else if str.contains(symbolName, "XAU")
    assetType := "METAL"

else if str.contains(symbolName, "XAG")
    assetType := "METAL"

else if str.contains(symbolName, "EUR")
    assetType := "FOREX"

else if str.contains(symbolName, "GBP")
    assetType := "FOREX"

//=============================================================================
// CORE VARIABLES
//=============================================================================

var string marketState = "UNKNOWN"
var float trendScore = 0.0
var float confidenceScore = 0.0
//=============================================================================
// STRUCTURE VARIABLES
//=============================================================================

var float lastSwingHigh = na
var float lastSwingLow  = na

var string structureDirection = "NEUTRAL"

var float structureScore = 0

var bool bullBOS = false
var bool bearBOS = false

var bool bullCHOCH = false
var bool bearCHOCH = false
//=============================================================================
// LIQUIDITY VARIABLES
//=============================================================================

var bool eqHighDetected = false
var bool eqLowDetected = false

var float equalHighPrice = na
var float equalLowPrice = na

var float liquidityScore = 0.0
//=============================================================================
// LIQUIDITY SWEEP VARIABLES
//=============================================================================

var bool bullSweep = false
var bool bearSweep = false

var float lastSweepPrice = na

var float sweepScore = 0.0
//=============================================================================
// CONFLUENCE VARIABLES
//=============================================================================

var float confluenceScore = 0.0
var string marketBias = "NEUTRAL"

var bool trendAligned = false
var bool structureAligned = false
var bool liquidityAligned = false
//=============================================================================
// MTF VARIABLES
//=============================================================================

var string htfTrend = "UNKNOWN"
var float htfEMA20 = na
var float htfEMA50 = na

var bool htfBullish = false
var bool htfBearish = false

var float mtfScore = 0.0
//=============================================================================
// FVG VARIABLES
//=============================================================================

var bool bullFVG = false
var bool bearFVG = false

var float bullFVGHigh = na
var float bullFVGLow = na

var float bearFVGHigh = na
var float bearFVGLow = na

var float fvgScore = 0.0
//=============================================================================
// ORDER BLOCK VARIABLES
//=============================================================================

var bool bullOB = false
var bool bearOB = false

var float bullOBHigh = na
var float bullOBLow = na

var float bearOBHigh = na
var float bearOBLow = na

var float orderBlockScore = 0.0
//=============================================================================
// PREMIUM / DISCOUNT VARIABLES
//=============================================================================

var float premiumLevel = na
var float equilibriumLevel = na
var float discountLevel = na

var string pdState = "UNKNOWN"

var float pdScore = 0.0
//=============================================================================
// SESSION VARIABLES
//=============================================================================

var bool asianSession = false
var bool londonSession = false
var bool newYorkSession = false

var bool londonKillZone = false
var bool newYorkKillZone = false

var float sessionHigh = na
var float sessionLow = na

var string activeSession = "NONE"

var float sessionScore = 0.0
//==============================================================
// SMART DECISION VARIABLES
//==============================================================

var float finalScore = 0.0

var string tradeGrade = "N/A"

var string entryQuality = "UNKNOWN"

var string riskRating = "UNKNOWN"
//=====================================================
// AI FILTER
//=====================================================

var bool allowLong = false
var bool allowShort = false
//=====================================================
// TRADE QUALITY ENGINE
//=====================================================

var string tradeQuality = "UNKNOWN"
//=====================================================
// RISK MANAGEMENT
//=====================================================

var float stopLoss = na
var float takeProfit1 = na
var float takeProfit2 = na
var float takeProfit3 = na

var float riskReward = na
//=====================================================
// ENTRY EXECUTION ENGINE
//=====================================================

var bool tradeReady = false

var float entryPrice = na

var string executionStatus = "WAIT"
//=====================================================
// INSTITUTIONAL CANDLE RATING ENGINE
//=====================================================

//=============================================================================
// BOS / CHOCH
//=============================================================================

var float previousSwingHigh = na
var float previousSwingLow  = na

//=====================================================
// AI SIGNAL PANEL
//=====================================================

var string aiSignal = "WAIT"

var float aiConfidence = 0.0

var int trendStars = 0
var int structureStars = 0
var int liquidityStars = 0
var int mtfStars = 0

var string riskLevel = "UNKNOWN"
//=============================================================================
// UTILITY FUNCTIONS
//=============================================================================

roundPrice(price) =>
    float result = math.round(price / syminfo.mintick) * syminfo.mintick
    result

percent(a, b) =>
    float result = b == 0 ? 0.0 : (a / b) * 100.0
    result
//=============================================================================
// DASHBOARD
//=============================================================================

var table dashboard = table.new(
     position.top_right,
     2,
     16,
     bgcolor=color.new(#1a1c2c, 0),
     frame_color=color.gray,
     frame_width=1)

//=====================================================
// TRADE SETUP TABLE
//=====================================================

var table tradeBox =
     table.new(
          position.bottom_right,
          2,
          10,
          bgcolor = color.new(color.white, 0),
          frame_color=color.gray,
          frame_width=1)
getTrendDirection() =>

    string dir = ""

    if trendScore >= 90
        dir := "ULTRA BULL"

    else if trendScore >= 75
        dir := "STRONG BULL"

    else if trendScore >= 60
        dir := "BULL"

    else if trendScore >= 40
        dir := "NEUTRAL"

    else if trendScore >= 25
        dir := "BEAR"

    else if trendScore >= 10
        dir := "STRONG BEAR"

    else
        dir := "ULTRA BEAR"

    dir
getTradeBoxPosition() =>

    switch tradeBoxPosition

        "Top Left" => position.top_left

        "Top Right" => position.top_right

        "Bottom Left" => position.bottom_left

        => position.bottom_right
//---------------------------------------------------------

clearDashboard() =>
    table.clear(dashboard,0,0,1,15)

//---------------------------------------------------------
// PAGE 1: SUMMARY -- quick top-level read
//---------------------------------------------------------

drawSummary() =>
    clearDashboard()

    table.cell(dashboard, 0, 0, "TITAN X — SUMMARY", text_color=color.white, bgcolor=color.new(#2962ff, 0))
    table.cell(dashboard, 1, 0, TITAN_VERSION, text_color=color.white, bgcolor=color.new(#2962ff, 0))

    table.cell(dashboard, 0, 1, "Symbol", text_color=color.white)
    table.cell(dashboard, 1, 1, symbolName, text_color=color.white)

    table.cell(dashboard, 0, 2, "TF / Asset", text_color=color.white)
    table.cell(dashboard, 1, 2, timeframeName + " / " + assetType, text_color=color.white)

    table.cell(dashboard, 0, 3, "Trend", text_color=color.white)
    table.cell(dashboard, 1, 3, getTrendDirection(), text_color=color.white)

    table.cell(dashboard, 0, 4, "Decision", text_color=color.white)
    table.cell(dashboard, 1, 4, marketState, text_color=color.white)

    table.cell(dashboard, 0, 5, "Bias", text_color=color.white)
    table.cell(dashboard, 1, 5, marketBias, text_color=color.white)

    table.cell(dashboard, 0, 6, "Trade Quality", text_color=color.white)
    table.cell(dashboard, 1, 6, tradeQuality, text_color=color.white)

    table.cell(dashboard, 0, 7, "Confidence", text_color=color.white)
    table.cell(dashboard, 1, 7, str.tostring(math.round(confidenceScore)) + "%", text_color=color.white)

    table.cell(dashboard, 0, 8, "Grade", text_color=color.white)
    table.cell(dashboard, 1, 8, tradeGrade, text_color=color.white)

    table.cell(dashboard, 0, 9, "Session", text_color=color.white)
    table.cell(dashboard, 1, 9, activeSession, text_color=color.white)

    table.cell(dashboard, 0, 10, "Kill Zone", text_color=color.white)
    table.cell(dashboard, 1, 10,
         londonKillZone ? "LONDON" :
         newYorkKillZone ? "NEW YORK" : "-", text_color=color.white)

    table.cell(dashboard, 0, 11, "Ready", text_color=color.white)
    table.cell(dashboard, 1, 11, confluenceScore >= 80 ? "YES" : "WAIT", text_color=color.white)

//---------------------------------------------------------
// PAGE 2: STRUCTURE -- market structure / liquidity
//---------------------------------------------------------

drawStructure() =>
    clearDashboard()

    table.cell(dashboard, 0, 0, "TITAN X — STRUCTURE", text_color=color.white, bgcolor=color.new(#2962ff, 0))
    table.cell(dashboard, 1, 0, TITAN_BUILD, text_color=color.white, bgcolor=color.new(#2962ff, 0))

    table.cell(dashboard, 0, 1, "Structure", text_color=color.white)
    table.cell(dashboard, 1, 1, structureDirection, text_color=color.white)

    table.cell(dashboard, 0, 2, "Struct Score", text_color=color.white)
    table.cell(dashboard, 1, 2, str.tostring(math.round(structureScore)), text_color=color.white)

    table.cell(dashboard, 0, 3, "BOS", text_color=color.white)
    table.cell(dashboard, 1, 3, bullBOS ? "BULL" : bearBOS ? "BEAR" : "-", text_color=color.white)

    table.cell(dashboard, 0, 4, "CHOCH", text_color=color.white)
    table.cell(dashboard, 1, 4, bullCHOCH ? "BULL" : bearCHOCH ? "BEAR" : "-", text_color=color.white)

    table.cell(dashboard, 0, 5, "EQH / EQL", text_color=color.white)
    table.cell(dashboard, 1, 5, (eqHighDetected ? "EQH " : "") + (eqLowDetected ? "EQL" : (eqHighDetected ? "" : "-")), text_color=color.white)

    table.cell(dashboard, 0, 6, "Liquidity Score", text_color=color.white)
    table.cell(dashboard, 1, 6, str.tostring(math.round(liquidityScore)), text_color=color.white)

    table.cell(dashboard, 0, 7, "Sweep", text_color=color.white)
    table.cell(dashboard, 1, 7, bullSweep ? "BULL" : bearSweep ? "BEAR" : "-", text_color=color.white)

    table.cell(dashboard, 0, 8, "Sweep Score", text_color=color.white)
    table.cell(dashboard, 1, 8, str.tostring(math.round(sweepScore)), text_color=color.white)

    table.cell(dashboard, 0, 9, "Confluence", text_color=color.white)
    table.cell(dashboard, 1, 9, str.tostring(math.round(confluenceScore)), text_color=color.white)

//---------------------------------------------------------
// PAGE 3: SMART MONEY -- FVG / OB / PD / HTF
//---------------------------------------------------------

drawSmartMoney() =>
    clearDashboard()

    table.cell(dashboard, 0, 0, "TITAN X — SMART MONEY", text_color=color.white, bgcolor=color.new(#2962ff, 0))
    table.cell(dashboard, 1, 0, TITAN_BUILD, text_color=color.white, bgcolor=color.new(#2962ff, 0))

    table.cell(dashboard, 0, 1, "Bull / Bear FVG", text_color=color.white)
    table.cell(dashboard, 1, 1, (bullFVG ? "BULL " : "") + (bearFVG ? "BEAR" : (bullFVG ? "" : "-")), text_color=color.white)

    table.cell(dashboard, 0, 2, "FVG Score", text_color=color.white)
    table.cell(dashboard, 1, 2, str.tostring(math.round(fvgScore)), text_color=color.white)

    table.cell(dashboard, 0, 3, "Bull / Bear OB", text_color=color.white)
    table.cell(dashboard, 1, 3, (bullOB ? "BULL " : "") + (bearOB ? "BEAR" : (bullOB ? "" : "-")), text_color=color.white)

    table.cell(dashboard, 0, 4, "OB Score", text_color=color.white)
    table.cell(dashboard, 1, 4, str.tostring(math.round(orderBlockScore)), text_color=color.white)

    table.cell(dashboard, 0, 5, "PD Zone", text_color=color.white)
    table.cell(dashboard, 1, 5, pdState, text_color=color.white)

    table.cell(dashboard, 0, 6, "PD Score", text_color=color.white)
    table.cell(dashboard, 1, 6, str.tostring(math.round(pdScore)), text_color=color.white)

    table.cell(dashboard, 0, 7, "Equilibrium", text_color=color.white)
    table.cell(dashboard, 1, 7, str.tostring(math.round(equilibriumLevel)), text_color=color.white)

    table.cell(dashboard, 0, 8, "HTF Trend", text_color=color.white)
    table.cell(dashboard, 1, 8, htfTrend, text_color=color.white)

    table.cell(dashboard, 0, 9, "MTF Score", text_color=color.white)
    table.cell(dashboard, 1, 9, str.tostring(math.round(mtfScore)), text_color=color.white)

    table.cell(dashboard, 0, 10, "MTF Align", text_color=color.white)
    table.cell(dashboard, 1, 10, mtfScore >= 50 ? "YES" : "NO", text_color=color.white)

//---------------------------------------------------------
// PAGE 4: EXECUTION -- entries, SL/TP, allow flags
//---------------------------------------------------------

drawExecution() =>
    clearDashboard()

    table.cell(dashboard, 0, 0, "TITAN X — EXECUTION", text_color=color.white, bgcolor=color.new(#2962ff, 0))
    table.cell(dashboard, 1, 0, TITAN_BUILD, text_color=color.white, bgcolor=color.new(#2962ff, 0))

    table.cell(dashboard, 0, 1, "Execution", text_color=color.white)
    table.cell(dashboard, 1, 1, executionStatus, text_color=color.white)

    table.cell(dashboard, 0, 2, "Trade Ready", text_color=color.white)
    table.cell(dashboard, 1, 2, tradeReady ? "YES" : "NO", text_color=color.white)

    table.cell(dashboard, 0, 3, "Allow Long/Short", text_color=color.white)
    table.cell(dashboard, 1, 3, allowLong ? "LONG" : allowShort ? "SHORT" : "-", text_color=color.white)

    table.cell(dashboard, 0, 4, "Entry", text_color=color.white)
    table.cell(dashboard, 1, 4, str.tostring(entryPrice), text_color=color.white)

    table.cell(dashboard, 0, 5, "SL", text_color=color.white)
    table.cell(dashboard, 1, 5, str.tostring(stopLoss), text_color=color.white)

    table.cell(dashboard, 0, 6, "TP1", text_color=color.white)
    table.cell(dashboard, 1, 6, str.tostring(takeProfit1), text_color=color.white)

    table.cell(dashboard, 0, 7, "TP2", text_color=color.white)
    table.cell(dashboard, 1, 7, str.tostring(takeProfit2), text_color=color.white)

    table.cell(dashboard, 0, 8, "TP3", text_color=color.white)
    table.cell(dashboard, 1, 8, str.tostring(takeProfit3), text_color=color.white)

    table.cell(dashboard, 0, 9, "R:R", text_color=color.white)
    table.cell(dashboard, 1, 9, "1:" + str.tostring(riskReward), text_color=color.white)

    table.cell(dashboard, 0, 10, "Entry Quality", text_color=color.white)
    table.cell(dashboard, 1, 10, entryQuality, text_color=color.white)

    table.cell(dashboard, 0, 11, "Risk Rating", text_color=color.white)
    table.cell(dashboard, 1, 11, riskRating, text_color=color.white)

//---------------------------------------------------------
// PAGE 5: STATISTICS -- all scoring components + final score
//---------------------------------------------------------

