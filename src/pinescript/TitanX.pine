//---------------------------------------------------------
// PAGE 6: DEBUG -- raw internal values for troubleshooting
//---------------------------------------------------------

drawDebug() =>
    clearDashboard()

    table.cell(dashboard, 0, 0, "TITAN X — DEBUG", text_color=color.white, bgcolor=color.new(#2962ff, 0))
    table.cell(dashboard, 1, 0, TITAN_BUILD, text_color=color.white, bgcolor=color.new(#2962ff, 0))

    table.cell(dashboard, 0, 1, "Bar Index", text_color=color.white)
    table.cell(dashboard, 1, 1, str.tostring(bar_index), text_color=color.white)

    table.cell(dashboard, 0, 2, "Session High", text_color=color.white)
    table.cell(dashboard, 1, 2, str.tostring(sessionHigh), text_color=color.white)

    table.cell(dashboard, 0, 3, "Session Low", text_color=color.white)
    table.cell(dashboard, 1, 3, str.tostring(sessionLow), text_color=color.white)

    table.cell(dashboard, 0, 4, "Last Swing High", text_color=color.white)
    table.cell(dashboard, 1, 4, str.tostring(lastSwingHigh), text_color=color.white)

    table.cell(dashboard, 0, 5, "Last Swing Low", text_color=color.white)
    table.cell(dashboard, 1, 5, str.tostring(lastSwingLow), text_color=color.white)

    table.cell(dashboard, 0, 6, "Prev Swing High", text_color=color.white)
    table.cell(dashboard, 1, 6, str.tostring(previousSwingHigh), text_color=color.white)

    table.cell(dashboard, 0, 7, "Prev Swing Low", text_color=color.white)
    table.cell(dashboard, 1, 7, str.tostring(previousSwingLow), text_color=color.white)

    table.cell(dashboard, 0, 8, "Equal High", text_color=color.white)
    table.cell(dashboard, 1, 8, str.tostring(equalHighPrice), text_color=color.white)

    table.cell(dashboard, 0, 9, "Equal Low", text_color=color.white)
    table.cell(dashboard, 1, 9, str.tostring(equalLowPrice), text_color=color.white)

    table.cell(dashboard, 0, 10, "Last Sweep", text_color=color.white)
    table.cell(dashboard, 1, 10, str.tostring(lastSweepPrice), text_color=color.white)

clearTradeBox() =>
    table.clear(tradeBox, 0, 0, 1, 9)
    
drawTradeBox() =>

    clearTradeBox()

    table.cell(tradeBox,0,0,"TITAN X SETUP")

    table.cell(tradeBox,0,1,"Signal")
    table.cell(tradeBox,1,1,marketState)

    table.cell(tradeBox,0,2,"Entry")
    table.cell(tradeBox,1,2,str.tostring(entryPrice))

    table.cell(tradeBox,0,3,"SL")
    table.cell(tradeBox,1,3,str.tostring(stopLoss))

    table.cell(tradeBox,0,4,"TP1")
    table.cell(tradeBox,1,4,str.tostring(takeProfit1))

    table.cell(tradeBox,0,5,"TP2")
    table.cell(tradeBox,1,5,str.tostring(takeProfit2))

    table.cell(tradeBox,0,6,"TP3")
    table.cell(tradeBox,1,6,str.tostring(takeProfit3))

    table.cell(tradeBox,0,7,"R:R")
    table.cell(tradeBox,1,7,"1 : "+str.tostring(riskReward))

    table.cell(tradeBox,0,8,"Status")
    table.cell(tradeBox,1,8,executionStatus)

    table.cell(tradeBox,0,9,"Ready")
    table.cell(tradeBox,1,9,tradeReady ? "YES" : "NO")
//---------------------------------------------------------

updateDashboard() =>

    if dashboardPage == "SUMMARY"
        drawSummary()

    else if dashboardPage == "STRUCTURE"
        drawStructure()

    else if dashboardPage == "SMART MONEY"
        drawSmartMoney()

    else if dashboardPage == "EXECUTION"
        drawExecution()

    else if dashboardPage == "STATISTICS"
        drawStatistics()

    else
        drawDebug()

   
//=============================================================================
// LOGGER
//=============================================================================

log(message)=>

    if debugMode and barstate.islast
        label.new(
             bar_index,
             high,
             message,
             style=label.style_label_down)

//=============================================================================
// ENGINE PLACEHOLDERS
//=============================================================================

//=============================================================================
// TREND ENGINE
//=============================================================================

// EMAs
ema20  = ta.ema(close,20)
ema50  = ta.ema(close,50)
ema100 = ta.ema(close,100)
ema200 = ta.ema(close,200)

//------------------------------------------------------------
// Trend Score
//------------------------------------------------------------
calculateTrend()=>

    float score = 0

    // EMA Alignment
    score += ema20 > ema50 ? 15 : 0
    score += ema50 > ema100 ? 15 : 0
    score += ema100 > ema200 ? 15 : 0

    // Price Position
    score += close > ema20 ? 10 : 0
    score += close > ema50 ? 10 : 0
    score += close > ema100 ? 10 : 0
    score += close > ema200 ? 10 : 0

    // EMA Slope
    score += ema20 > ema20[1] ? 5 : 0
    score += ema50 > ema50[1] ? 5 : 0
    score += ema100 > ema100[1] ? 3 : 0
    score += ema200 > ema200[1] ? 2 : 0

    score
    //=============================================================================
// HIGHER TIMEFRAME DATA
//=============================================================================

if enableMTF

    htfEMA20 := request.security(
        syminfo.tickerid,
        higherTF,
        ta.ema(close,20))

    htfEMA50 := request.security(
        syminfo.tickerid,
        higherTF,
        ta.ema(close,50))

    htfBullish := htfEMA20 > htfEMA50
    htfBearish := htfEMA20 < htfEMA50

//------------------------------------------------------------
// Confidence
//------------------------------------------------------------
calculateConfidence()=>

    float confidence = 0

    confidence += trendScore * 0.30
    confidence += structureScore * 0.20
    confidence += liquidityScore * 0.15
    confidence += sweepScore * 0.10
    confidence += mtfScore * 0.10
    confidence += fvgScore * 0.05
    confidence += pdScore * 0.05
    confidence += sessionScore * 0.05

    math.min(confidence,100)

getStars(score) =>

    score >= 90 ? "★★★★★" :
    score >= 75 ? "★★★★☆" :
    score >= 60 ? "★★★☆☆" :
    score >= 40 ? "★★☆☆☆" :
    score >= 20 ? "★☆☆☆☆" :
    "☆☆☆☆☆"    
    
//==============================================================
// FINAL SCORE ENGINE
//==============================================================

calculateFinalScore()=>

    float finalScore = 0.0

    //----------------------------------------------------------
    // Trend (25%)
    //----------------------------------------------------------
    finalScore += math.max(trendScore,0) * 0.25

    //----------------------------------------------------------
    // Structure (15%)
    //----------------------------------------------------------
    finalScore += math.max(structureScore,0) * 0.15

    //----------------------------------------------------------
    // Liquidity (10%)
    //----------------------------------------------------------
    finalScore += math.max(liquidityScore,0) * 0.10

    //----------------------------------------------------------
    // Sweep (10%)
    //----------------------------------------------------------
    finalScore += math.max(sweepScore,0) * 0.10

    //----------------------------------------------------------
    // Higher Timeframe (10%)
    //----------------------------------------------------------
    finalScore += math.max(mtfScore,0) * 0.10

    //----------------------------------------------------------
    // Fair Value Gap (8%)
    //----------------------------------------------------------
    finalScore += math.max(fvgScore,0) * 0.08

    //----------------------------------------------------------
    // Order Block (7%)
    //----------------------------------------------------------
    finalScore += math.max(orderBlockScore,0) * 0.07

    //----------------------------------------------------------
    // Premium / Discount (5%)
    //----------------------------------------------------------
    finalScore += math.max(pdScore,0) * 0.05

    //----------------------------------------------------------
    // Session (5%)
    //----------------------------------------------------------
    finalScore += math.max(sessionScore,0) * 0.05

    //----------------------------------------------------------
    // Clamp
    //----------------------------------------------------------
    math.min(finalScore,100)
    //==============================================================

//------------------------------------------------------------
// Decision
//------------------------------------------------------------
//==============================================================
// SMART DECISION ENGINE
//==============================================================

calculateSmartDecision()=>

    float score = calculateFinalScore()

    string result = "WAIT"

    if allowLong and score >= 85
        result := "STRONG BUY"

    else if allowLong
        result := "BUY"

    else if allowShort and score <=15
        result := "STRONG SELL"

    else if allowShort
        result := "SELL"

    else
        result := "WAIT"

    result

//------------------------------------------------------------
// Trend Direction
//------------------------------------------------------------

    //=============================================================================
// SMART MARKET STRUCTURE ENGINE
//=============================================================================

pivotHigh = ta.pivothigh(high, pivotLeft, pivotRight)
pivotLow  = ta.pivotlow(low, pivotLeft, pivotRight)

if not na(pivotHigh)

    if not na(lastSwingHigh)

        if pivotHigh > lastSwingHigh

            structureDirection := "HH"

            structureScore := math.min(structureScore + 15, 100)

            if showStructureLabels
                label.new(
                    bar_index-pivotRight,
                    pivotHigh,
                    "HH",
                    style=label.style_label_down,
                    color=color.green,
                    textcolor=color.white)

        else

            structureDirection := "LH"

            structureScore := math.max(structureScore - 15, 0)

            if showStructureLabels
                label.new(
                    bar_index-pivotRight,
                    pivotHigh,
                    "LH",
                    style=label.style_label_down,
                    color=color.red,
                    textcolor=color.white)

    previousSwingHigh := lastSwingHigh
    lastSwingHigh := pivotHigh

//------------------------------------------------------

//------------------------------------------------------
// LOW STRUCTURE
//------------------------------------------------------

if not na(pivotLow)

    if not na(lastSwingLow)

        if pivotLow > lastSwingLow

            structureDirection := "HL"
            structureScore := math.min(structureScore + 15, 100)

            if showStructureLabels
                label.new(
                    bar_index - pivotRight,
                    pivotLow,
                    "HL",
                    style = label.style_label_up,
                    color = color.green,
                    textcolor = color.white
                )

        else

            structureDirection := "LL"
            structureScore := math.max(structureScore - 15, 0)

            if showStructureLabels
                label.new(
                    bar_index - pivotRight,
                    pivotLow,
                    "LL",
                    style = label.style_label_up,
                    color = color.red,
                    textcolor = color.white
                )

    previousSwingLow := lastSwingLow
    lastSwingLow := pivotLow
    //=============================================================================
// LIQUIDITY ENGINE
//=============================================================================

eqHighDetected := false
eqLowDetected := false

if not na(lastSwingHigh) and not na(previousSwingHigh)

    float highDiff =
         math.abs(lastSwingHigh - previousSwingHigh)

    float highTolerance =
         lastSwingHigh * eqTolerance / 100

    if highDiff <= highTolerance

        eqHighDetected := true
        equalHighPrice := lastSwingHigh

        liquidityScore :=
             math.min(liquidityScore + 20, 100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 equalHighPrice,
                 "EQH",
                 style = label.style_label_down,
                 color = color.orange,
                 textcolor = color.white)

if not na(lastSwingLow) and not na(previousSwingLow)

    float lowDiff =
         math.abs(lastSwingLow - previousSwingLow)

    float lowTolerance =
         lastSwingLow * eqTolerance / 100

    if lowDiff <= lowTolerance

        eqLowDetected := true
        equalLowPrice := lastSwingLow

        liquidityScore :=
             math.min(liquidityScore + 20,100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 equalLowPrice,
                 "EQL",
                 style = label.style_label_up,
                 color = color.orange,
                 textcolor = color.white)
                 //=============================================================================
// LIQUIDITY SWEEP ENGINE
//=============================================================================

bullSweep := false
bearSweep := false

//------------------------------------
// Bearish Sweep
//------------------------------------

if eqHighDetected

    if high > equalHighPrice and close < equalHighPrice

        bearSweep := true
        lastSweepPrice := high

        sweepScore := math.min(sweepScore + 40, 100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 high,
                 "Bear Sweep",
                 style = label.style_label_down,
                 color = color.red,
                 textcolor = color.white)

//------------------------------------
// Bullish Sweep
//------------------------------------

if eqLowDetected

    if low < equalLowPrice and close > equalLowPrice

        bullSweep := true
        lastSweepPrice := low

        sweepScore := math.min(sweepScore + 40, 100)

        if showLiquidityLabels
            label.new(
                 bar_index,
                 low,
                 "Bull Sweep",
                 style = label.style_label_up,
                 color = color.lime,
                 textcolor = color.black)
                 //=============================================================================
// CONFLUENCE ENGINE
//=============================================================================

confluenceScore := 0

//----------------------------------------------------
// Trend
//----------------------------------------------------

trendAligned := trendScore >= 70

if trendAligned
    confluenceScore += 30

//----------------------------------------------------
// Structure
//----------------------------------------------------

structureAligned :=
     structureDirection == "HH" or
     structureDirection == "HL"

if structureAligned
    confluenceScore += 30

//----------------------------------------------------
// Liquidity
//----------------------------------------------------

liquidityAligned :=
     bullSweep or
     bearSweep or
     eqHighDetected or
     eqLowDetected

if liquidityAligned
    confluenceScore += 40

//----------------------------------------------------
// Market Bias
//----------------------------------------------------

marketBias := "NEUTRAL"

if confluenceScore >= 80
    marketBias := "BULLISH"

else if confluenceScore <= 20
    marketBias := "BEARISH"
    //=============================================================================
// MTF ENGINE
//=============================================================================

mtfScore := 0

if enableMTF

    if htfBullish
        mtfScore += 50

    if htfBearish
        mtfScore -= 50

    if htfBullish and trendScore >= 70
        mtfScore += 50

    if htfBearish and trendScore <= 30
        mtfScore -= 50

if mtfScore > 100
    mtfScore := 100

if mtfScore < -100
    mtfScore := -100

if htfBullish
    htfTrend := "BULLISH"

else if htfBearish
    htfTrend := "BEARISH"

else
    htfTrend := "SIDEWAYS"
    //=============================================================================
// FAIR VALUE GAP ENGINE
//=============================================================================

bullFVG := false
bearFVG := false

//-------------------------------------
// Bullish FVG
//-------------------------------------

if low > high[2]

    gapSize = (low - high[2]) / syminfo.mintick

    if gapSize >= minFVGTicks

        bullFVG := true

        bullFVGHigh := low
        bullFVGLow := high[2]

        fvgScore := math.min(fvgScore + 20,100)

        if showFVG
            box.new(
                 bar_index-2,
                 low,
                 bar_index,
                 high[2],
                 bgcolor=color.new(color.green,85),
                 border_color=color.green)

//-------------------------------------
// Bearish FVG
//-------------------------------------

if high < low[2]

    gapSize = (low[2]-high)/syminfo.mintick

    if gapSize >= minFVGTicks

        bearFVG := true

        bearFVGHigh := low[2]
        bearFVGLow := high

        fvgScore := math.min(fvgScore+20,100)

        if showFVG
            box.new(
                 bar_index-2,
                 low[2],
                 bar_index,
                 high,
                 bgcolor=color.new(color.red,85),
                 border_color=color.red)
                //=============================================================================
// ORDER BLOCK ENGINE
//=============================================================================

bullOB := false
bearOB := false

//--------------------------------------------------
// Bullish Order Block
//--------------------------------------------------

if ta.lowest(low, obLookback) == low and close > open

    bullOB := true

    bullOBHigh := high
    bullOBLow := low

    orderBlockScore := math.min(orderBlockScore + 15, 100)

    if showOrderBlocks
        box.new(
            bar_index,
            high,
            bar_index + 5,
            low,
            bgcolor = color.new(color.green, 85),
            border_color = color.green)

//--------------------------------------------------
// Bearish Order Block
//--------------------------------------------------

if ta.highest(high, obLookback) == high and close < open

    bearOB := true

    bearOBHigh := high
    bearOBLow := low

    orderBlockScore := math.min(orderBlockScore + 15, 100)

    if showOrderBlocks
        box.new(
            bar_index,
            high,
            bar_index + 5,
            low,
            bgcolor = color.new(color.red, 85),
            border_color = color.red)
            //=============================================================================
// PREMIUM / DISCOUNT ENGINE
//=============================================================================

swingHigh = ta.highest(high, pdLookback)
swingLow  = ta.lowest(low, pdLookback)

priceRange = swingHigh - swingLow

premiumLevel := swingLow + priceRange * 0.75
equilibriumLevel := swingLow + priceRange * 0.50
discountLevel := swingLow + priceRange * 0.25
pdScore := 50

if close >= premiumLevel
    pdState := "PREMIUM"
    pdScore := 0

else if close <= discountLevel
    pdState := "DISCOUNT"
    pdScore := 100

else
    pdState := "EQUILIBRIUM"
    pdScore := 50
    //=============================================================================
// SESSION DETECTION
//=============================================================================

currentHour = hour(time, sessionTimezone)

asianSession := currentHour >= 0 and currentHour < 8

londonSession := currentHour >= 8 and currentHour < 16

newYorkSession := currentHour >= 13 and currentHour < 22

londonKillZone := currentHour >= 8 and currentHour < 10

newYorkKillZone := currentHour >= 13 and currentHour < 16

activeSession := "NONE"

if asianSession
    activeSession := "ASIA"

if londonSession
    activeSession := "LONDON"

if newYorkSession
    activeSession := "NEW YORK"
    // Session High Low

if activeSession != activeSession[1]

    sessionHigh := high
    sessionLow := low

else

    sessionHigh := math.max(sessionHigh, high)
    sessionLow := math.min(sessionLow, low)
    sessionScore := 50

if londonKillZone
    sessionScore := 100

else if newYorkKillZone
    sessionScore := 95

else if londonSession
    sessionScore := 80

else if newYorkSession
    sessionScore := 75

else if asianSession
    sessionScore := 40
//=============================================================================
// BREAK OF STRUCTURE
//=============================================================================

bullBOS := false
bearBOS := false

if not na(lastSwingHigh)
    bullBOS := close > lastSwingHigh

if not na(lastSwingLow)
    bearBOS := close < lastSwingLow
    //=============================================================================
// CHANGE OF CHARACTER
//=============================================================================

bullCHOCH := false
bearCHOCH := false

if structureDirection == "LL" and bullBOS
    bullCHOCH := true

if structureDirection == "HH" and bearBOS
    bearCHOCH := true
//=====================================================
// ENTRY EXECUTION ENGINE
//=====================================================

//=====================================================
// INSTITUTIONAL CANDLE ENGINE
//=====================================================

//=============================================================================
// MAIN
//=============================================================================

trendScore := calculateTrend()

confidenceScore := calculateConfidence()

finalScore := calculateFinalScore()
//-----------------------------------------------------
// TRADE QUALITY
//-----------------------------------------------------

if finalScore >= 95
    tradeQuality := "⭐ PLATINUM"

else if finalScore >= 90
    tradeQuality := "🟢 A+"

else if finalScore >= 80
    tradeQuality := "🔵 A"

else if finalScore >= 70
    tradeQuality := "🟡 B"

else if finalScore >= 60
    tradeQuality := "🟠 C"

else
    tradeQuality := "🔴 AVOID"
//-----------------------------------------------------
// AI FILTER
//-----------------------------------------------------

allowLong :=
     finalScore >= 75 and
     trendScore >= 60 and
     structureScore >= 60 and
     liquidityScore >= 50 and
     htfBullish

allowShort :=
     finalScore <= 30 and
     trendScore <= 40 and
     structureScore <= 40 and
     liquidityScore >= 50 and
     htfBearish
     //=====================================================
// RISK MANAGEMENT ENGINE
//=====================================================

if allowLong

    stopLoss := sessionLow

    risk = close - stopLoss

    takeProfit1 := close + risk

    takeProfit2 := close + risk * 2

    takeProfit3 := close + risk * 3

    riskReward := 3

if allowShort

    stopLoss := sessionHigh

    risk = stopLoss - close

    takeProfit1 := close - risk

    takeProfit2 := close - risk * 2

    takeProfit3 := close - risk * 3

    riskReward := 3
    //=====================================================
// ENTRY EXECUTION ENGINE
//=====================================================

tradeReady := false

executionStatus := "WAIT"

entryPrice := na

if allowLong

    if finalScore >= 80

        tradeReady := true

        executionStatus := "BUY READY"

        entryPrice := close

if allowShort

    if finalScore <= 25

        tradeReady := true

        executionStatus := "SELL READY"

        entryPrice := close
//----------------------------------------------------
// Trade Grade
//----------------------------------------------------

if finalScore >= 90
    tradeGrade := "A+"
else if finalScore >= 80
    tradeGrade := "A"
else if finalScore >= 70
    tradeGrade := "B"
else if finalScore >= 60
    tradeGrade := "C"
else
    tradeGrade := "D"

//----------------------------------------------------
// Entry Quality
//----------------------------------------------------

if finalScore >= 85
    entryQuality := "EXCELLENT"
else if finalScore >= 70
    entryQuality := "GOOD"
else if finalScore >= 50
    entryQuality := "AVERAGE"
else
    entryQuality := "POOR"

//----------------------------------------------------
// Risk Rating
//----------------------------------------------------

if finalScore >= 85
    riskRating := "LOW"
else if finalScore >= 65
    riskRating := "MEDIUM"
else
    riskRating := "HIGH"

marketState := calculateSmartDecision()

if showDashboard and barstate.islast
    updateDashboard()

if showTradeBox
    drawTradeBox()
    
plot(ema20,"EMA20",color=color.orange,linewidth=2)
plot(ema50,"EMA50",color=color.blue)
plot(ema100,"EMA100",color=color.green)
plot(ema200,"EMA200",color=color.red)
plot(showPDZones ? premiumLevel : na,
     title = "Premium",
     color = color.red)

plot(showPDZones ? equilibriumLevel : na,
     title = "Equilibrium",
     color = color.yellow)

plot(showPDZones ? discountLevel : na,
     title = "Discount",
     color = color.green)
plot(showSessions ? sessionHigh : na,
     title="Session High",
     color=color.green)

plot(showSessions ? sessionLow : na,
     title="Session Low",
     color=color.red)